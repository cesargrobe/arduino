// denominar os pinos de cada LED
#define led1 13
#define led2 12
#define led3 11
#define led4 10
#define led5 9

//identificar modo de cada pino
void setup () {
  pinMode(led1, OUTPUT); //OUTPUT - saída de energia
  pinMode(led2, OUTPUT); //INPUT - entrada de sinal
  pinMode(led3, OUTPUT);
  pinMode(led4, OUTPUT);
  pinMode(led5, OUTPUT);
}

//programar o loop de funcionamento
void loop () {
  //método para ligar e desligar os LEDs
  digitalWrite(led1, HIGH); 
  delay(500);
  digitalWrite(led2, HIGH);
  delay(500);
  digitalWrite(led3, HIGH);
  delay(500);
  digitalWrite(led4, HIGH);
  delay(500);
  digitalWrite(led5, HIGH);
  delay(500);
  digitalWrite(led5, LOW);
  delay(500);
  digitalWrite(led4, LOW);
  delay(500);
  digitalWrite(led3, LOW);
  delay(500);
  digitalWrite(led2, LOW);
  delay(500);
  digitalWrite(led1, LOW);
  delay(500);
}


